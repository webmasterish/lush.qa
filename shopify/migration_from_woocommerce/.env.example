# Copy to .env and fill in real values. .env is gitignored — never commit real credentials.

# --- WooCommerce source (lush.qa) ---
# REST API (WooCommerce > Settings > Advanced > REST API)
WOO_STORE_URL=https://lush.qa
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=

# Direct DB access (optional, for data not exposed via REST) — requires SSH/FTP from IT
WOO_DB_HOST=
WOO_DB_PORT=3306
WOO_DB_NAME=
WOO_DB_USER=
WOO_DB_PASSWORD=
WOO_DB_TABLE_PREFIX=wp_

# --- Shopify target (dev store: lush-qatar.myshopify.com) ---
SHOPIFY_STORE_DOMAIN=lush-qatar.myshopify.com
SHOPIFY_API_VERSION=2025-07

# Dev Dashboard app "DotAim - Lush Qatar Store Ops" OAuth credentials
# (from the app's Settings > Credentials; used by scripts/get_admin_token.py)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Offline Admin API token (shpat_...), minted via scripts/get_admin_token.py.
# Required for orderCreate and the bulk migration; push_demo_seed.py uses it when set.
SHOPIFY_ADMIN_API_TOKEN=
