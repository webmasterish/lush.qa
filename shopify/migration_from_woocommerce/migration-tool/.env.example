# Per-project secrets template.
# Copy to config/projects/<project-name>.env (gitignored) — one env file per
# project, next to its <project-name>.json. Never commit real credentials.

# --- WooCommerce source (read-only REST API key) ---
WOO_STORE_URL=https://example.com
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=

# --- Shopify target ---
SHOPIFY_STORE_DOMAIN=example.myshopify.com
SHOPIFY_API_VERSION=2025-07

# Offline Admin API token (shpat_/shpca_...), minted via `npm run cli -- mint-token`.
# Required for all loads; orderCreate does not work with online (CLI) tokens.
SHOPIFY_ADMIN_API_TOKEN=

# Dev Dashboard app OAuth credentials — only needed by mint-token.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
